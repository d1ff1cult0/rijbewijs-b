// Prisma schema — Belgisch Rijbewijs B Theorie & Oefenplatform
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum QuestionType {
  EXAM // Kan in een proefexamen verschijnen
  THEORY // Tussentijdse herhalingsvraag binnen een theorieles
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum AttemptMode {
  EXAM // Volledig proefexamen (50 vragen, officieel format)
  PRACTICE // Vrij oefenen per categorie / adaptief
  MISTAKES // Foutenboek herhalen
}

enum SignGroup {
  GEVAAR // Gevaarsborden (type A)
  VERBOD // Verbodsborden (type C)
  GEBOD // Gebodsborden (type D)
  VOORRANG // Voorrangsborden (type B)
  AANWIJZING // Aanwijzingsborden (type F)
  ONDERBORD // Onderborden / aanvullende borden
}

// ----------------------------------------------------------------------------
// Inhoud: categorieën, lessen, vragen
// ----------------------------------------------------------------------------

model Category {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String
  // Aantal vragen dat standaard uit deze categorie getrokken wordt in een
  // proefexamen (samen ~50). Weerspiegelt het gewicht in het echte examen.
  examWeight  Int      @default(4)
  order       Int      @default(0)
  icon        String   @default("BookOpen") // lucide-react icoonnaam
  color       String   @default("#2563eb")

  lessons   TheoryLesson[]
  questions Question[]

  @@index([order])
}

model TheoryLesson {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  title      String
  intro      String   @db.Text
  order      Int      @default(0)
  estMinutes Int      @default(10)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  sections TheorySection[]

  @@index([categoryId])
}

model TheorySection {
  id       Int     @id @default(autoincrement())
  heading  String
  body     String  @db.Text // Uitleg (ondersteunt eenvoudige markdown)
  imageUrl String?
  imageAlt String?
  order    Int     @default(0)

  lessonId Int
  lesson   TheoryLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // Mini-quizvragen die bij dit subonderdeel horen (type THEORY)
  questions Question[]

  @@index([lessonId])
}

model Question {
  id          Int          @id @default(autoincrement())
  text        String       @db.Text
  explanation String       @db.Text // Uitleg bij het juiste antwoord
  imageUrl    String? // Optionele afbeelding (verkeerssituatie of bord)
  imageAlt    String?
  type        QuestionType @default(EXAM)
  difficulty  Difficulty   @default(MEDIUM)
  // "Zware fout": in het echte examen kan dit direct buizen betekenen
  isSevere    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Indien gekoppeld aan een theorie-subonderdeel (mini-quiz)
  sectionId Int?
  section   TheorySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  options     Option[]
  userAnswers UserAnswer[]

  @@index([categoryId])
  @@index([type])
  @@index([sectionId])
}

model Option {
  id         Int     @id @default(autoincrement())
  text       String  @db.Text
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  userAnswers UserAnswer[]

  @@index([questionId])
}

// ----------------------------------------------------------------------------
// Verkeersborden (borden-trainer / flashcards)
// ----------------------------------------------------------------------------

model TrafficSign {
  id       Int       @id @default(autoincrement())
  code     String    @unique // bv. "A1", "B1", "C1", "D1", "F1"
  name     String
  group    SignGroup
  meaning  String    @db.Text
  imageUrl String
  order    Int       @default(0)

  @@index([group])
}

// ----------------------------------------------------------------------------
// Resultaten / voortgang (single-user, gekoppeld aan een anonieme sessiesleutel)
// ----------------------------------------------------------------------------

model ExamAttempt {
  id             String      @id @default(cuid())
  sessionKey     String // Anonieme sleutel uit cookie (geen login)
  mode           AttemptMode @default(EXAM)
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?
  totalQuestions Int         @default(0)
  correctCount   Int         @default(0)
  score          Int         @default(0) // Behaalde punten (examen: start 50)
  passed         Boolean     @default(false)
  severeErrors   Int         @default(0)
  lightErrors    Int         @default(0)
  durationSec    Int         @default(0)

  answers UserAnswer[]

  @@index([sessionKey])
  @@index([mode])
}

model UserAnswer {
  id           String   @id @default(cuid())
  isCorrect    Boolean  @default(false)
  isSevere     Boolean  @default(false)
  timeSpentSec Int      @default(0)
  answeredAt   DateTime @default(now())

  attempt       ExamAttempt @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  examAttemptId String

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  selectedOptionId Int?
  selectedOption   Option? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@index([examAttemptId])
  @@index([questionId])
}
